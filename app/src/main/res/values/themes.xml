<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- App 基础主题：淡蓝色系 -->
    <style name="Base.Theme.时矩" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- 主色：淡蓝色 -->
        <item name="colorPrimary">@color/blue_primary</item>
        <!-- 主色上面的文字颜色（白色） -->
        <item name="colorOnPrimary">@color/white</item>
        <!-- 主色的浅色容器 -->
        <item name="colorPrimaryContainer">@color/blue_primary_light</item>
        <!-- 浅色容器上的文字 -->
        <item name="colorOnPrimaryContainer">@color/text_primary</item>
        <!-- 页面背景色 -->
        <item name="android:colorBackground">@color/background_light</item>
        <!-- 卡片/表面背景色 -->
        <item name="colorSurface">@color/background_white</item>
    </style>

    <style name="Theme.时矩" parent="Base.Theme.时矩" />
</resources>