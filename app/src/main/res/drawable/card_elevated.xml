<?xml version="1.0" encoding="utf-8"?>
<!-- 高级浮起卡片：双层阴影 + 强玻璃感 + 圆角 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 深层阴影 -->
    <item
        android:bottom="-4dp"
        android:left="-2dp"
        android:right="-2dp"
        android:top="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/shadow_medium" />
            <corners android:radius="@dimen/card_radius" />
        </shape>
    </item>
    <!-- 浅层阴影 -->
    <item
        android:bottom="-2dp"
        android:left="-1dp"
        android:right="-1dp"
        android:top="2dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/shadow_soft" />
            <corners android:radius="@dimen/card_radius" />
        </shape>
    </item>
    <!-- 卡片主体 -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_fill_strong" />
            <stroke
                android:width="0.5dp"
                android:color="@color/glass_stroke" />
            <corners android:radius="@dimen/card_radius" />
        </shape>
    </item>
    <!-- 顶部高光 -->
    <item
        android:bottom="0dp"
        android:top="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/glass_highlight" />
            <corners
                android:topLeftRadius="@dimen/card_radius"
                android:topRightRadius="@dimen/card_radius"
                android:bottomLeftRadius="0dp"
                android:bottomRightRadius="0dp" />
            <size android:height="1dp" />
        </shape>
    </item>
</layer-list>
