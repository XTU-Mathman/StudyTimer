<?xml version="1.0" encoding="utf-8"?>
<!-- 底部线输入框样式：只有底部 1dp 雾蓝线条，Material3 风格 -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- 底部线 -->
    <item
        android:left="0dp"
        android:right="0dp"
        android:top="47dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/blue_pale" />
        </shape>
    </item>
    <!-- 透明主体 -->
    <item
        android:left="0dp"
        android:right="0dp"
        android:top="0dp"
        android:bottom="0dp">
        <shape android:shape="rectangle">
            <solid android:color="#00FFFFFF" />
        </shape>
    </item>
</layer-list>
