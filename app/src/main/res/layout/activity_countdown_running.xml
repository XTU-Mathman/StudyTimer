<?xml version="1.0" encoding="utf-8"?>
<!-- 全屏倒计时：毛玻璃背景 → 大数字 → 分割线 → 药丸按钮 → 底部格言 -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 自定义背景图片 -->
    <ImageView
        android:id="@+id/iv_background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <!-- 渐变遮罩层 -->
    <View
        android:id="@+id/v_overlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_overlay_gradient" />

    <!-- 内容层 -->
    <LinearLayout
        android:id="@+id/layout_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        android:padding="40dp">

        <!-- 顶部弹性 -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 科目信息 -->
        <TextView
            android:id="@+id/tv_subject_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="数学 — 高数"
            android:textSize="15sp"
            android:textColor="@color/text_tertiary"
            android:layout_marginBottom="8dp" />

        <!-- 目标时长 -->
        <TextView
            android:id="@+id/tv_target_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="目标：1小时30分"
            android:textSize="13sp"
            android:textColor="@color/text_tertiary"
            android:layout_marginBottom="28dp" />

        <!-- 计时大数字（带微阴影增加立体感） -->
        <TextView
            android:id="@+id/tv_timer_display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="01:30:00"
            android:textSize="64sp"
            android:textColor="#FFE57373"
            android:textStyle="bold"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.05"
            android:shadowColor="#33E57373"
            android:shadowDx="0"
            android:shadowDy="2"
            android:shadowRadius="4" />

        <!-- 分割细线 -->
        <View
            android:layout_width="80dp"
            android:layout_height="2dp"
            android:background="#FFE8C8C8"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="28dp" />

        <!-- 按钮行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:orientation="horizontal"
            android:gravity="center"
            android:weightSum="2">

            <Button
                android:id="@+id/btn_pause_resume"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="12dp"
                android:text="暂停"
                android:textSize="16sp"
                android:textColor="@color/white"
                android:background="@drawable/btn_pill_primary" />

            <Button
                android:id="@+id/btn_end"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="提前结束"
                android:textSize="16sp"
                android:textColor="@color/error"
                android:background="@drawable/btn_pill_danger" />

        </LinearLayout>

        <!-- 底部弹性 -->
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- 底部格言 -->
        <TextView
            android:id="@+id/tv_motto"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="自律即自由"
            android:textSize="13sp"
            android:textColor="@color/text_tertiary"
            android:gravity="center"
            android:layout_marginBottom="8dp" />

    </LinearLayout>

</FrameLayout>
