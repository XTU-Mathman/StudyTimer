<?xml version="1.0" encoding="utf-8"?>
<!-- 我的页面：动态背景 + 玻璃卡片菜单（含所有必需的 view ID） -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_page">

    <!-- 动态背景层 -->
    <com.example.studytimer.DynamicBackgroundView
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- 内容层 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- 页面标题 -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="我的"
                android:textSize="26sp"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:paddingBottom="20dp" />

            <!-- ===== 自定义计时背景 ===== -->
            <LinearLayout
                android:id="@+id/item_background"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/card_glass"
                android:elevation="1dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🖼 自定义计时背景"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_bg_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未设置"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  >"
                    android:textSize="18sp"
                    android:textColor="@color/text_tertiary" />

            </LinearLayout>

            <TextView
                android:id="@+id/btn_clear_bg"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="清除背景图片"
                android:textSize="14sp"
                android:textColor="#FFE57373"
                android:gravity="center"
                android:background="@drawable/card_glass"
                android:elevation="1dp"
                android:layout_marginBottom="8dp"
                android:visibility="gone" />

            <!-- ===== 格言管理 ===== -->
            <LinearLayout
                android:id="@+id/item_motto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/card_glass"
                android:elevation="1dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💬 格言管理"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="自律座右铭，轮换显示"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  >"
                    android:textSize="18sp"
                    android:textColor="@color/text_tertiary" />

            </LinearLayout>

            <!-- ===== 自律打卡 ===== -->
            <LinearLayout
                android:id="@+id/item_checkin"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/card_glass"
                android:elevation="1dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✅ 自律打卡"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_checkin_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0/0 已打卡"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  >"
                    android:textSize="18sp"
                    android:textColor="@color/text_tertiary" />

            </LinearLayout>

            <!-- ===== 白噪音 ===== -->
            <LinearLayout
                android:id="@+id/item_white_noise"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/card_glass"
                android:elevation="1dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🌧 白噪音"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_noise_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未启用"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  >"
                    android:textSize="18sp"
                    android:textColor="@color/text_tertiary" />

            </LinearLayout>

            <!-- ===== 音乐 ===== -->
            <LinearLayout
                android:id="@+id/item_music"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/card_glass"
                android:elevation="1dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎵 音乐"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_music_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="未启用"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  >"
                    android:textSize="18sp"
                    android:textColor="@color/text_tertiary" />

            </LinearLayout>

            <!-- ===== 纯净模式 ===== -->
            <LinearLayout
                android:id="@+id/item_pure_mode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp"
                android:background="@drawable/card_glass"
                android:elevation="1dp"
                android:layout_marginBottom="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔋 纯净模式"
                        android:textSize="16sp"
                        android:textColor="@color/text_primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_pure_mode_status"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="关闭"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="  >"
                    android:textSize="18sp"
                    android:textColor="@color/text_tertiary" />

            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</FrameLayout>
